VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
RESEND_API_KEY=

# API Configuration
# Set to 'local' to use localhost backend, 
# Set to 'railway' to use Railway deployment
# set to 'railway_staging' to use Railway staging deployment
VITE_API_MODE=local

# Local development URL
VITE_LOCAL_API_URL=http://127.0.0.1:8002

# Local/dev only. VITE_* values are public in browser bundles; do not set this in production.
VITE_BACKEND_API_KEY=

# Railway production URL
VITE_RAILWAY_API_URL=
# Railway staging URL
VITE_RAILWAY_API_URL_STAGING=

VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# Rebrickable API Key for parts lookup
# Get your key from: https://rebrickable.com/api/
VITE_REBRICKABLE_API_KEY=

# BrickOwl API Key for wishlist creation
# Get your key from: https://www.brickowl.com/my/api
# Leave empty to test without actual wishlist creation
VITE_BRICKOWL_API_KEY=

# Enable streaming for 3D generation (defaults to false/non-streaming)
# Set to 'true' to enable streaming by default
VITE_ENABLE_STREAMING=false